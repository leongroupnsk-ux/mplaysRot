# ── Среда ────────────────────────────────────────────────────────────────────
APP_ENV=development

# ── Безопасность ──────────────────────────────────────────────────────────────
# Замени оба значения перед запуском командами из раздела «Генерация ключей»
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_ENCRYPTION_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=attribly
POSTGRES_USER=attribly
POSTGRES_PASSWORD=attribly_test_2024

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis_test_2024

# ── ClickHouse (не запускается, значения нужны только чтобы приложение стартовало)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=attribly
CLICKHOUSE_USER=attribly
CLICKHOUSE_PASSWORD=dummy_not_used

# ── Kafka (не запускается)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CLICKS=attribly.clicks
KAFKA_TOPIC_ORDERS=attribly.orders
KAFKA_TOPIC_EVENTS=attribly.events
KAFKA_GROUP_ID=etl-consumer

# ── Celery (in-memory, без воркеров) ─────────────────────────────────────────
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# ── MinIO (не запускается) ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioaccess
MINIO_SECRET_KEY=miniosecret
MINIO_BUCKET=attribly-reports
MINIO_BUCKET_RAW=attribly-raw
MINIO_BUCKET_PROCESSED=attribly-processed
MINIO_SECURE=false
MINIO_PRESIGNED_TTL=3600

# ── Прочее ───────────────────────────────────────────────────────────────────
SEGMENT_QUEUE_KEY=queue:segment_jobs
WORKER_POLL_INTERVAL=2.0
NOTIFICATIONS_CHANNEL=notifications
BATCH_SIZE=500
FLUSH_INTERVAL=5.0
MODELS_DIR=/tmp/attribly-models
GRAFANA_PASSWORD=testpass
SENTRY_DSN=
