# Copy this file to app-secrets.yaml, fill in real values, then:
#   kubectl apply -f infra/k8s/secrets/app-secrets.yaml
#
# Values must be base64-encoded:
#   echo -n "your-value" | base64
#
# NEVER commit the filled-in file — it is gitignored.

apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: attribly
type: Opaque
data:
  # python -c "import secrets; print(secrets.token_hex(32))" | base64
  SECRET_KEY: ""
  # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" | base64
  ENCRYPTION_KEY: ""

  POSTGRES_PASSWORD: ""
  CLICKHOUSE_PASSWORD: ""
  REDIS_PASSWORD: ""

  MINIO_ACCESS_KEY: ""
  MINIO_SECRET_KEY: ""

  # redis://:PASSWORD@redis:6379/1  (base64)
  CELERY_BROKER_URL: ""
  # redis://:PASSWORD@redis:6379/2  (base64)
  CELERY_RESULT_BACKEND: ""

  GRAFANA_PASSWORD: ""

  # Optional — leave empty string ("" | base64 = "") to disable
  SENTRY_DSN: ""
