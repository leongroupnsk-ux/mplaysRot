# ──────────────────────────────────────────────────────────────────────────────
# Attribly — environment variables template
#
# Copy this file to .env and fill in all required values:
#   cp .env.example .env
#
# Lines marked  ← REQUIRED  have no default and must be set before `docker compose up`.
# Lines marked  ← GENERATE  should be generated with a secure random command:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# DO NOT commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

# Runtime environment: development | staging | production
# Controls OpenAPI docs visibility (/docs hidden in production), log verbosity, etc.
APP_ENV=development


# ── Security ──────────────────────────────────────────────────────────────────

# Shared HMAC secret used for JWT signing.
# Must be identical across: api-gateway, reporting, notifications.
# Min 32 bytes. Changing this invalidates all existing tokens.
SECRET_KEY=                                # ← GENERATE: python -c "import secrets; print(secrets.token_hex(32))"

# Symmetric key for encrypting OAuth tokens stored in the database (Fernet).
# 32 bytes, URL-safe base64. Changing this invalidates all stored credentials.
ENCRYPTION_KEY=                            # ← GENERATE: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# JWT algorithm. Change to RS256 only if you switch to a public/private key pair.
JWT_ALGORITHM=HS256

# Access token lifetime in minutes. Default 1440 = 24 hours.
JWT_EXPIRE_MINUTES=1440


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by: api-gateway, segmentation, alembic migrations

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=attribly
POSTGRES_USER=attribly
POSTGRES_PASSWORD=                         # ← REQUIRED


# ── ClickHouse ────────────────────────────────────────────────────────────────
# Used by: api-gateway (analytics queries), etl, reporting, segmentation, ml, tracking

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=attribly
CLICKHOUSE_USER=attribly
CLICKHOUSE_PASSWORD=                       # ← REQUIRED


# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by: api-gateway (query cache, Celery broker), tracking, notifications, segmentation

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                            # ← REQUIRED (matches `redis-server --requirepass`)


# ── Kafka ─────────────────────────────────────────────────────────────────────
# Used by: tracking (producer), etl (consumer)

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_CLICKS=attribly.clicks
KAFKA_TOPIC_ORDERS=attribly.orders
KAFKA_TOPIC_EVENTS=attribly.events
# Consumer group — change if you need multiple independent ETL pipelines
KAFKA_GROUP_ID=etl-consumer


# ── MinIO (S3-compatible object storage) ──────────────────────────────────────
# Used by: reporting (CSV export), etl (raw & processed data dumps)
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
# in the minio container defined in docker-compose.yml.

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=                          # ← REQUIRED
MINIO_SECRET_KEY=                          # ← REQUIRED
MINIO_BUCKET=attribly-reports
MINIO_BUCKET_RAW=attribly-raw
MINIO_BUCKET_PROCESSED=attribly-processed
# Set to true when MinIO sits behind HTTPS in production
MINIO_SECURE=false
# Lifetime of presigned download URLs for exported reports (seconds)
MINIO_PRESIGNED_TTL=3600


# ── Celery ────────────────────────────────────────────────────────────────────
# Used by: api-gateway celery-worker (async tasks) + celery-beat (scheduled jobs)
# DB 1 = broker queue, DB 2 = task results

CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2


# ── Internal service configuration ────────────────────────────────────────────

# Redis key the segmentation worker listens on via BLPOP
SEGMENT_QUEUE_KEY=queue:segment_jobs

# How long the segmentation worker sleeps between polls when the queue is empty (s)
WORKER_POLL_INTERVAL=2.0

# Redis pub/sub channel used for WebSocket notification fan-out
NOTIFICATIONS_CHANNEL=notifications

# ETL: number of ClickHouse rows to buffer before flushing
BATCH_SIZE=500

# ETL: maximum seconds between flushes regardless of batch fullness
FLUSH_INTERVAL=5.0

# Directory inside the ml container where trained models are persisted
MODELS_DIR=/app/models


# ── Observability ─────────────────────────────────────────────────────────────

# Grafana admin password (used by the grafana container in docker-compose.yml)
GRAFANA_PASSWORD=                          # ← REQUIRED

# Sentry DSN for server-side error tracking. Leave blank to disable.
SENTRY_DSN=


# ── Ad platform integrations ──────────────────────────────────────────────────
# These tokens are per-user credentials stored encrypted in the database.
# The values below are only for local dev / connector smoke tests.
# In production each user connects their own account via the UI.

# Yandex Direct
YANDEX_DIRECT_TOKEN=
YANDEX_DIRECT_CLIENT_LOGIN=

# Yandex Audience (used by segmentation for lookalike uploads)
YANDEX_AUDIENCE_TOKEN=

# VK Ads
VK_ADS_TOKEN=
VK_ADS_ACCOUNT_ID=

# Telegram Ads
TELEGRAM_ADS_TOKEN=

# Messenger MAX
MESSENGER_MAX_TOKEN=
MESSENGER_MAX_WEBHOOK_SECRET=


# ── Marketplace integrations ──────────────────────────────────────────────────
# Same as above — stored per-user encrypted in DB. Dev/test values only.

# Wildberries
WB_API_KEY=

# Ozon
OZON_CLIENT_ID=
OZON_API_KEY=

# Yandex Market
YANDEX_MARKET_OAUTH_TOKEN=
YANDEX_MARKET_CLIENT_ID=
YANDEX_MARKET_CAMPAIGN_ID=

# Amazon SP-API (stub connector — not fully implemented yet)
AMAZON_REFRESH_TOKEN=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_MARKETPLACE_ID=A1F83G8C2ARO7P      # A1F83G8C2ARO7P = EU; ATVPDKIKX0DER = US


# ── OAuth login providers ─────────────────────────────────────────────────────
# Used for "Login with Yandex / VK" flows. Not required for email/password auth.

YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=

VK_OAUTH_CLIENT_ID=
VK_OAUTH_CLIENT_SECRET=

TELEGRAM_BOT_TOKEN=
